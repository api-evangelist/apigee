      "items": [
        {
          "info": {
            "name": "Apigee List APIs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://apigeeregistry.googleapis.com/v1/projects/:projectId/locations/:locationId/apis",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path",
                "description": "Google Cloud project ID."
              },
              {
                "name": "locationId",
                "value": "",
                "type": "path",
                "description": "Google Cloud region or location."
              },
              {
                "name": "pageSize",
                "value": "",
                "type": "query",
                "description": "Maximum number of items to return per page."
              },
              {
                "name": "pageToken",
                "value": "",
                "type": "query",
                "description": "Page token returned from a previous list request."
              },
              {
                "name": "filter",
                "value": "",
                "type": "query",
                "description": "Filter expression to narrow the results."
              },
              {
                "name": "orderBy",
                "value": "",
                "type": "query",
                "description": "Field to order results by."
              }
            ]
          },
          "docs": "Lists all APIs in the specified project and location. Returns API metadata including name, display name, description, and labels."
        },
        {
          "info": {
            "name": "Apigee Create an API",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://apigeeregistry.googleapis.com/v1/projects/:projectId/locations/:locationId/apis",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path",
                "description": "Google Cloud project ID."
              },
              {
                "name": "locationId",
                "value": "",
                "type": "path",
                "description": "Google Cloud region or location."
              },
              {
                "name": "apiId",
                "value": "",
                "type": "query",
                "description": "Required. The ID to use for the API."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new API entry in the registry. An API represents a logical grouping of related API versions."
        },
        {
          "info": {
            "name": "Apigee Get an API",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://apigeeregistry.googleapis.com/v1/projects/:projectId/locations/:locationId/apis/:apiId",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path",
                "description": "Google Cloud project ID."
              },
              {
                "name": "locationId",
                "value": "",
                "type": "path",
                "description": "Google Cloud region or location."
              },
              {
                "name": "apiId",
                "value": "",
                "type": "path",
                "description": "ID of the API resource."
              }
            ]
          },
          "docs": "Gets the details of a specific API entry in the registry."
        },
        {
          "info": {
            "name": "Apigee Update an API",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://apigeeregistry.googleapis.com/v1/projects/:projectId/locations/:locationId/apis/:apiId",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path",
                "description": "Google Cloud project ID."
              },
              {
                "name": "locationId",
                "value": "",
                "type": "path",
                "description": "Google Cloud region or location."
              },
              {
                "name": "apiId",
                "value": "",
                "type": "path",
                "description": "ID of the API resource."
              },
              {
                "name": "updateMask",
                "value": "",
                "type": "query",
                "description": "Required. Comma-separated list of fields to update."
              },
              {
                "name": "allowMissing",
                "value": "",
                "type": "query",
                "description": "If true, create the API if it does not exist."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates an existing API entry. Use updateMask to specify fields."
        },
        {
          "info": {
            "name": "Apigee Delete an API",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://apigeeregistry.googleapis.com/v1/projects/:projectId/locations/:locationId/apis/:apiId",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path",
                "description": "Google Cloud project ID."
              },
              {
                "name": "locationId",
                "value": "",
                "type": "path",
                "description": "Google Cloud region or location."
              },
              {
                "name": "apiId",
                "value": "",
                "type": "path",
                "description": "ID of the API resource."
              },
              {
                "name": "force",
                "value": "",
                "type": "query",
                "description": "If true, delete child resources as well."
              }
            ]
          },
          "docs": "Deletes an API and all of its owned resources (versions, specs, deployments, artifacts)."
        }
      ]
    },
