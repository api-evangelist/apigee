{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ValueType",
  "title": "ValueType",
  "type": "object",
  "description": "A value with a specific type.",
  "properties": {
    "stringValue": {
      "type": "string"
    },
    "intValue": {
      "type": "string",
      "format": "int64"
    },
    "doubleValue": {
      "type": "number",
      "format": "double"
    },
    "booleanValue": {
      "type": "boolean"
    },
    "stringArray": {
      "type": "object",
      "properties": {
        "stringValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "jsonValue": {
      "type": "string"
    }
  }
}